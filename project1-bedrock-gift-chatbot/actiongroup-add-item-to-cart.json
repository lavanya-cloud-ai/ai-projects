{
  "openapi": "3.0.0",
  "info": {
    "title": "Add to Cart API",
    "description": "Adds a product to the user's shopping cart",
    "version": "1.0.0"
  },
  "paths": {
    "/cart/items": {
      "post": {
        "summary": "Add item to cart",
        "description": "Adds a specified quantity of a product to the user's cart. Use this when the user wants to purchase or add a product.",
        "operationId": "addToCart",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["userId", "productId", "productName", "quantity", "price"],
                "properties": {
                  "userId": {
                    "type": "string",
                    "description": "The user's email address. Always use the email provided by the user, never generate or substitute with placeholder values like U123."
                  },
                  "productId": {
                    "type": "string",
                    "description": "The product ID mapped from the 'product_id' field as returned from the products API. Never generate or assume this value."
                  },
                  "productName": {
                    "type": "string",
                    "description": "The full product name mapped from the 'product_name' field as returned from the products API. This field is mandatory and must never be omitted."
                  },
                  "quantity": {
                    "type": "integer",
                    "description": "Number of units to add. Default to 1 if not specified by the user.",
                    "minimum": 1,
                    "default": 1
                  },
                  "price": {
                    "type": "number",
                    "description": "The exact price mapped from the 'price' field as returned from the products API. Must be a numeric value greater than 0. Never default to 0 or omit this field."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Item successfully added to cart",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "Whether the operation was successful"
                    },
                    "message": {
                      "type": "string",
                      "description": "Human-readable result message"
                    },
                    "cart": {
                      "type": "object",
                      "description": "Updated cart summary",
                      "properties": {
                        "userId": {
                          "type": "string",
                          "description": "The user's email address"
                        },
                        "updatedItem": {
                          "type": "object",
                          "description": "The item that was added or updated",
                          "properties": {
                            "productId": {
                              "type": "string",
                              "description": "Product ID that was added"
                            },
                            "productName": {
                              "type": "string",
                              "description": "Product name that was added"
                            },
                            "quantity": {
                              "type": "integer",
                              "description": "Quantity that was added"
                            },
                            "price": {
                              "type": "number",
                              "description": "Price per unit"
                            }
                          }
                        },
                        "cartItemCount": {
                          "type": "integer",
                          "description": "Total number of items in cart after update"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request — missing or malformed parameters",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "description": "Description of what went wrong"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
